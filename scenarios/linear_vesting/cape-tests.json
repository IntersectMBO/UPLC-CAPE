                "datum": "@vesting_datum"
              }
            ]
          }
        }
      ]
    },
    {
      "name": "partial_unlock_between_installments",
      "description": "PartialUnlock at time=25 with 800 tokens remaining should succeed (between installment boundaries)",
      "expected": {
        "type": "value",
        "content": "(con unit ())"
      },
      "inputs": [
        {
          "type": "script_context",
          "script_context": {
            "baseline": "@successful_partial_unlock",
            "patches": [
              {
                "op": "set_valid_range",
