    {
      "name": "full_unlock_after_period_end",
      "description": "FullUnlock at time=101 (just after vesting period end) should succeed",
      "expected": {
        "type": "value",
        "content": "(con unit ())"
      },
      "inputs": [
        {
          "type": "script_context",
          "script_context": {
            "baseline": "@successful_full_unlock",
            "patches": []
          }
        }
      ]
    },
    {
      "name": "full_unlock_well_after",
      "description": "FullUnlock at time=200 (well after vesting period end) should succeed",
      "expected": {
        "type": "value",
        "content": "(con unit ())"
      },
      "inputs": [
        {
          "type": "script_context",
          "script_context": {
            "baseline": "@successful_full_unlock",
            "patches": [
              {
                "op": "set_valid_range",
                "from_time": 200
              }
            ]
          }
        }
      ]
