{
  "version": "1.0.0",
  "description": "Test cases for linear vesting smart contract validator",
  "data_structures": {
    "beneficiary_pubkey": {
      "type": "builtin_data",
      "value": "#aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa"
    },
    "impostor_pubkey": {
      "type": "builtin_data",
      "value": "#cccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccc"
    },
    "currency_symbol_raw": {
      "type": "builtin_data",
      "value": "#dddddddddddddddddddddddddddddddddddddddddddddddddddddddd"
    },
    "token_name_raw": {
      "type": "builtin_data",
      "value": "#76657374"
    },
    "vesting_datum": {
      "type": "builtin_data",
      "value": "0(0(0(#aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa) 1()) 0(#dddddddddddddddddddddddddddddddddddddddddddddddddddddddd #76657374) 1000 0 100 10 10)"
    },
    "modified_vesting_datum": {
      "type": "builtin_data",
      "value": "0(0(0(#aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa) 1()) 0(#dddddddddddddddddddddddddddddddddddddddddddddddddddddddd #76657374) 2000 0 100 10 10)"
    },
    "successful_partial_unlock": {
      "type": "script_context",
      "script_context": {
        "baseline": "spending",
        "patches": [
          {
            "op": "set_redeemer",
            "redeemer": "0()"
          },
          {
            "op": "set_script_datum",
            "datum": "@vesting_datum"
          },
          {
            "op": "add_signature",
            "pubkey_hash": "@beneficiary_pubkey"
          },
          {
            "op": "set_valid_range",
            "from_time": 11
          },
          {
            "op": "add_input_utxo",
            "utxo_ref": "3333333333333333333333333333333333333333333333333333333333333333:0",
            "value": {
              "lovelace": 2000000,
              "assets": [
                {
                  "currency_symbol": "@currency_symbol_raw",
                  "token_name": "@token_name_raw",
                  "quantity": 1000
                }
              ]
            },
            "is_own_input": true,
            "datum": "@vesting_datum"
          },
          {
            "op": "add_output_utxo",
            "address": {
              "type": "script",
              "script_hash": "1111111111111111111111111111111111111111111111111111111111"
            },
            "value": {
              "lovelace": 2000000,
              "assets": [
                {
                  "currency_symbol": "@currency_symbol_raw",
                  "token_name": "@token_name_raw",
                  "quantity": 900
                }
              ]
            },
            "datum": "@vesting_datum"
          }
        ]
      }
    },
    "successful_full_unlock": {
      "type": "script_context",
      "script_context": {
        "baseline": "spending",
        "patches": [
          {
            "op": "set_redeemer",
            "redeemer": "1()"
          },
          {
            "op": "set_script_datum",
            "datum": "@vesting_datum"
          },
          {
            "op": "add_signature",
            "pubkey_hash": "@beneficiary_pubkey"
          },
          {
            "op": "set_valid_range",
            "from_time": 101
          },
          {
            "op": "add_input_utxo",
            "utxo_ref": "3333333333333333333333333333333333333333333333333333333333333333:0",
            "value": {
              "lovelace": 2000000,
              "assets": [
                {
                  "currency_symbol": "@currency_symbol_raw",
                  "token_name": "@token_name_raw",
                  "quantity": 1000
                }
              ]
            },
            "is_own_input": true,
            "datum": "@vesting_datum"
          }
        ]
      }
    }
  },
  "tests": [
    {
      "name": "redeemer_integer_0",
      "description": "Validator fails when redeemer is raw integer 0 instead of constructor 0()",
      "expected": {
        "type": "error"
      },
      "inputs": [
        {
          "type": "builtin_data",
          "value": "0"
        }
      ]
    },
    {
      "name": "redeemer_integer_1",
      "description": "Validator fails when redeemer is raw integer 1 instead of constructor 1()",
      "expected": {
        "type": "error"
      },
      "inputs": [
        {
          "type": "builtin_data",
          "value": "1"
        }
      ]
    },
    {
      "name": "redeemer_integer_99",
      "description": "Validator fails when redeemer is raw integer 99 (not a valid constructor)",
      "expected": {
        "type": "error"
      },
      "inputs": [
        {
          "type": "builtin_data",
          "value": "99"
        }
      ]
    },
    {
      "name": "redeemer_bytestring",
      "description": "Validator fails when redeemer is bytestring instead of constructor",
      "expected": {
        "type": "error"
      },
      "inputs": [
        {
          "type": "builtin_data",
          "value": "#deadbeef"
        }
      ]
    },
    {
      "name": "redeemer_list",
      "description": "Validator fails when redeemer is list [1 2 3] instead of constructor",
      "expected": {
        "type": "error"
      },
      "inputs": [
        {
          "type": "builtin_data",
          "value": "[1 2 3]"
        }
      ]
    },
    {
      "name": "partial_unlock_first_installment",
      "description": "PartialUnlock at time=11 with 900 tokens remaining should succeed (first installment unlocked)",
      "expected": {
        "type": "value",
        "content": "(con unit ())"
      },
      "inputs": [
        {
          "type": "script_context",
          "script_context": {
            "baseline": "@successful_partial_unlock",
            "patches": []
          }
        }
      ]
    },
    {
      "name": "partial_unlock_mid_vesting",
      "description": "PartialUnlock at time=50 with 500 tokens remaining should succeed (half vested)",
      "expected": {
        "type": "value",
        "content": "(con unit ())"
