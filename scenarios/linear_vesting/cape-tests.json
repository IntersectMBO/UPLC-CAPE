    {
      "name": "partial_unlock_missing_signature",
      "description": "PartialUnlock without beneficiary signature should fail",
      "expected": {
        "type": "error"
      },
      "inputs": [
        {
          "type": "script_context",
          "script_context": {
            "baseline": "@successful_partial_unlock",
            "patches": [
              {
                "op": "remove_signature",
                "pubkey_hash": "@beneficiary_pubkey"
              }
            ]
          }
        }
      ]
    },
    {
      "name": "partial_unlock_wrong_signature",
      "description": "PartialUnlock with impostor signature instead of beneficiary should fail",
      "expected": {
