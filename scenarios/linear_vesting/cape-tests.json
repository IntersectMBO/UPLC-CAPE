      "inputs": [
        {
          "type": "script_context",
          "script_context": {
            "baseline": "@successful_partial_unlock",
            "patches": [
              {
                "op": "remove_signature",
                "pubkey_hash": "@beneficiary_pubkey"
              },
              {
                "op": "add_signature",
