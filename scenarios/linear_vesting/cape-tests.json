                },
                "value": {
                  "lovelace": 2000000,
                  "assets": [
                    {
                      "currency_symbol": "@currency_symbol_raw",
                      "token_name": "@token_name_raw",
                      "quantity": 500
                    }
                  ]
                },
                "datum": "@vesting_datum"
              }
            ]
          }
        }
      ]
    },
    {
      "name": "partial_unlock_near_end",
      "description": "PartialUnlock at time=91 with 100 tokens remaining should succeed (9 installments unlocked)",
      "expected": {
        "type": "value",
        "content": "(con unit ())"
      },
      "inputs": [
        {
          "type": "script_context",
          "script_context": {
            "baseline": "@successful_partial_unlock",
            "patches": [
              {
                "op": "set_valid_range",
